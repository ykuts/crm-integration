generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("CRM_DATABASE_URL")
}

model BotOrder {
  id                 Int      @id @default(autoincrement())
  botOrderId         String   @unique @map("bot_order_id")
  source             String
  chatId             String   @map("chat_id")
  sendpulseDealId    String?  @map("sendpulse_deal_id")
  sendpulseContactId String?  @map("sendpulse_contact_id")
  customerPhone      String   @map("customer_phone")
  customerName       String   @map("customer_name")
  totalAmount        Float    @map("total_amount")
  paymentMethod      String   @map("payment_method")
  deliveryInfo       String   @map("delivery_info")
  notes              String?
  products           String
  status             String   @default("PENDING")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  customerEmail      String?  @map("customer_email")
  metadata           String   @default("{}")

  @@index([botOrderId])
  @@index([source])
  @@index([customerPhone])
  @@index([status])
  @@index([createdAt])
  @@map("bot_orders")
}

model ProductMapping {
  id                 Int       @id @default(autoincrement())
  ecommerceId        Int       @unique @map("ecommerce_id")
  sendpulseId        Int       @map("sendpulse_id")
  name               String

  // KeyCRM integration fields
  keycrmId           Int?     @map("keycrm_id")      // numeric product ID in KeyCRM
  keycrmSku          String?  @map("keycrm_sku")     // SKU/article in KeyCRM e.g. SYR-101-500-P

  lastSyncAt         DateTime? @map("last_sync_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  syncStatus         String    @default("ACTIVE") @map("sync_status")
  googleSheetsColumn String?   @map("google_sheets_column")

  @@index([ecommerceId])
  @@index([sendpulseId])
  @@index([googleSheetsColumn])
  @@index([keycrmSku])
  @@map("product_mappings")
}

model CustomerMapping {
  id          Int       @id @default(autoincrement())
  ecommerceId Int?      @map("ecommerce_id")
  sendpulseId String    @map("sendpulse_id")
  phone       String    @unique
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  email       String?
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  lastSyncAt  DateTime? @map("last_sync_at")
  syncStatus  String    @default("ACTIVE") @map("sync_status")

  @@index([phone])
  @@index([email])
  @@index([sendpulseId])
  @@map("customer_mappings")
}

model ApiLog {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now()) @map("created_at")
  method       String
  endpoint     String
  statusCode   Int      @map("status_code")
  userType     String?  @map("user_type")
  userId       String?  @map("user_id")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  responseTime Int?     @map("response_time")
  context      String   @default("{}")
  errorMessage String?  @map("error_message")

  @@index([endpoint])
  @@index([statusCode])
  @@index([userType])
  @@index([createdAt])
  @@map("api_logs")
}

model BotCartItem {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  telegramId  String   @map("telegram_id")
  contactId   String   @map("contact_id")
  productId   Int      @map("product_id")
  productName String   @map("product_name")
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)
  weightKg    Decimal  @default(0) @map("weight_kg") @db.Decimal(10, 3)
  total       Decimal  @db.Decimal(10, 2)

  @@index([telegramId])
  @@index([contactId])
  @@index([productId])
  @@map("bot_cart_items")
}
